PORT=3001
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
DATABASE_URL=postgresql://mahjong:mahjong@localhost:5432/mahjong
POSTGRES_PASSWORD=change-this-in-prod
SESSION_SECRET=change-this-to-a-random-64-char-string
SESSION_TTL_SECONDS=7200
COOKIE_DOMAIN=localhost
ROOM_IDLE_TIMEOUT_SECONDS=1800
DISCONNECT_GRACE_SECONDS=60
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
CLIENT_ORIGIN=http://localhost:5173
VITE_WS_URL=ws://localhost:3001
VITE_API_BASE=/api/v1
LOG_LEVEL=info

# Prod only (docker-compose.prod.yml): public WSS URL baked into the client build,
# and the public domain Google OAuth redirects back to after login.
PROD_WS_URL=wss://mahjong.example.com
